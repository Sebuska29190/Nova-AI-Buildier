# ═══════════════════════════════════════════════════════════════
# Nova AI Platform — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.
# Only the providers you configure will be available.

# ─── LLM Providers ────────────────────────────────────────────
# Uncomment and set API keys for the providers you use:

# DeepSeek (recommended default)
# DEEPSEEK_API_KEY=sk-your-key-here

# OpenAI — GPT-4.1, GPT-4o-mini, o3-mini
# OPENAI_API_KEY=sk-...

# Anthropic — Claude Sonnet 4, Haiku 4, Opus 4
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=...

# xAI Grok
# XAI_API_KEY=...

# Moonshot Kimi
# KIMI_API_KEY=...

# MiniMax
# MINIMAX_API_KEY=...

# Alibaba Qwen (DashScope)
# DASHSCOPE_API_KEY=...

# Zhipu AI (GLM)
# ZHIPU_API_KEY=...

# LM Studio (local) — requires LM Studio running locally
# LMSTUDIO_API_KEY=not-needed

# Ollama (local) — requires Ollama running locally
# OLLAMA_API_KEY=not-needed

# Custom OpenAI-compatible endpoint
# CUSTOM_API_KEY=...
# CUSTOM_BASE_URL=http://localhost:8000/v1

# ─── Other API Keys ───────────────────────────────────────────
# These are optional, used by specific tools:

# Pexels — for image search in video generation
# PEXELS_API_KEY=...

# Unsplash — for image search in video generation
# UNSPLASH_ACCESS_KEY=...

# Trading / Financial data
# ALPHA_VANTAGE_API_KEY=...
# POLYGON_API_KEY=...

# Search
# TAVILY_API_KEY=...
# SERP_API_KEY=...

# ─── Server Configuration ─────────────────────────────────────
NOVA_PORT=4123
NOVA_HOST=0.0.0.0
NOVA_UI_DIR=./packages/ui/dist

# Optional: custom database path
# NOVA_DB_PATH=./custom-path.db

# Optional: custom JWT secret (auto-generated if not set)
# NOVA_JWT_SECRET=your-secret-here

# Optional: API authentication token (sets require Bearer token for all API)
# NOVA_AUTH_TOKEN=nv-your-secret-token

# Optional: encryption key for stored API keys (auto-generated if not set)
# NOVA_ENCRYPTION_KEY=...

# ─── Bluesky Social ──────────────────────────────────────────
# App Password: Settings → App Passwords → Create App Password
# BSKY_IDENTIFIER=your-handle.bsky.social
# BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── Crypto / DEX Trading ────────────────────────────────────
# Solana wallet for DEX trading (Jupiter)
# SOLANA_PRIVATE_KEY=your-base58-private-key
# SOLANA_WALLET_ADDRESS=your-wallet-address
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# JUPITER_API_KEY=your-jupiter-api-key

# Whale tracking
# ETHERSCAN_API_KEY=...
# BSCSCAN_API_KEY=...
# WHALE_ALERT_KEY=...

# ─── Messaging Channels ─────────────────────────────────────
# Telegram Bot
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# Discord Bot
# DISCORD_TOKEN=...

# Email (IMAP + SMTP)
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USER=you@gmail.com
# EMAIL_IMAP_PASS=app-password
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=you@gmail.com
# EMAIL_SMTP_PASS=app-password

# Signal
# SIGNAL_PHONE=+1234567890
# SIGNAL_CLI_PATH=/path/to/signal-cli

# ─── Media & Creative ───────────────────────────────────────
# Replicate (image/video generation)
# REPLICATE_API_TOKEN=...

# FFmpeg path (if not in PATH)
# FFMPEG_PATH=/path/to/ffmpeg

# Python path (for Whisper STT, subtitle burning)
# PYTHON_PATH=/usr/bin/python3

# ─── Social Media APIs ──────────────────────────────────────
# Spotify
# SPOTIFY_ACCESS_TOKEN=...

# YouTube Data API
# YOUTUBE_API_KEY=...

# Twitter/X Bearer Token
# TWITTER_BEARER_TOKEN=...

# ─── IoT / Smart Home ───────────────────────────────────────
# Philips Hue
# HUE_BRIDGE_IP=192.168.1.x
# HUE_API_KEY=your-hue-api-key

# ─── Server Configuration ─────────────────────────────────────
NOVA_PORT=4123
NOVA_HOST=0.0.0.0
NOVA_UI_DIR=./packages/ui/dist

# Optional: custom database path
# NOVA_DB_PATH=./custom-path.db

# Optional: custom JWT secret (auto-generated if not set)
# NOVA_JWT_SECRET=your-secret-here

# Optional: API authentication token (sets require Bearer token for all API)
# NOVA_AUTH_TOKEN=nv-your-secret-token

# Optional: encryption key for stored API keys (auto-generated if not set)
# NOVA_ENCRYPTION_KEY=...

# Optional: CORS origin (default: http://localhost:4123)
# NOVA_CORS_ORIGIN=http://localhost:5173
